# Spring profile
SPRING_PROFILES_ACTIVE=local

# Server
SERVER_PORT=8080

# PostgreSQL (local profile defaults shown)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logmonitor
DB_USERNAME=logmonitor
DB_PASSWORD=logmonitor

# JWT (required - use a strong random secret, min 256 bits)
JWT_SECRET=change-me-to-a-secure-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# SSH
SSH_CONNECTION_TIMEOUT_MS=30000
SSH_COMMAND_TIMEOUT_MS=60000
SSH_MAX_RETRIES=3
SSH_RETRY_DELAY_MS=2000
SSH_KNOWN_HOSTS_PATH=C:/Users/YourName/.ssh/known_hosts

# AES encryption key for SSH private keys (required - 32-byte base64 or hex)
ENCRYPTION_SECRET_KEY=change-me-to-a-secure-encryption-key
